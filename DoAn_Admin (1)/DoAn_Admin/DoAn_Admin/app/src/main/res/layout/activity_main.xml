<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <!-- 🧭 HEADER -->
    <include
        android:id="@+id/headerLayout"
        layout="@layout/activity_header" />

    <!-- 🧾 MAIN CONTENT -->
    <ScrollView
        android:id="@+id/scrollMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:layout_above="@id/footerMenu"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 🔷 Tiêu đề -->
            <TextView
                android:text="THỐNG KÊ HỆ THỐNG"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#212121"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- 💠 2 CardView thống kê -->
            <LinearLayout
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center">

                <!-- 🔔 Cảnh báo -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAlert"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="120dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/txtAlertCount"
                            android:text="0"
                            android:textStyle="bold"
                            android:textSize="28sp"
                            android:textColor="#E53935"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="Cảnh báo"
                            android:textSize="14sp"
                            android:textColor="#666"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 👥 Người dùng -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUser"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="120dp"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/txtUserCount"
                            android:text="0"
                            android:textStyle="bold"
                            android:textSize="28sp"
                            android:textColor="#2962FF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="Người dùng"
                            android:textSize="14sp"
                            android:textColor="#666"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- 🔔 Danh sách cảnh báo -->
            <TextView
                android:text="Cảnh báo SOS mới nhất"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingBottom="20dp" />
            <TextView
                android:id="@+id/txtEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có cảnh báo SOS nào."
                android:textColor="#777"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone"
                android:textSize="14sp"/>
        </LinearLayout>
    </ScrollView>

    <!-- 🧩 FOOTER MENU -->
    <include
        android:id="@+id/footerMenu"
        layout="@layout/admin_footer_menu"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
