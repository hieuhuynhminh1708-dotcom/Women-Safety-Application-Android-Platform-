<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Bo góc -->
    <corners android:radius="12dp" />

    <!-- Màu nền -->
    <solid android:color="#FFFFFF" />

    <!-- Viền nhẹ -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" />

    <!-- Bóng đổ (chỉ hoạt động Android 5.0+) -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />

</shape>
