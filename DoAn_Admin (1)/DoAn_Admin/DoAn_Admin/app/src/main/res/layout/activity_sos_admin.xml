<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <include
        android:id="@+id/headerLayout"
        layout="@layout/activity_header" />

    <!-- Thanh thống kê -->
    <LinearLayout
        android:id="@+id/statsBar"
        android:layout_below="@id/headerLayout"
        android:orientation="horizontal"
        android:weightSum="3"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txtTotalAlerts"
                android:text="0"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="Tổng SOS"
                android:textSize="12sp"
                android:textColor="#777"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txtSmsSent"
                android:text="0"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#2962FF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="Đã gửi SMS"
                android:textSize="12sp"
                android:textColor="#777"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txtCallDone"
                android:text="0"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#E53935"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="Đã gọi"
                android:textSize="12sp"
                android:textColor="#777"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Thanh tìm kiếm -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_below="@id/statsBar"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/edtSearch"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:hint="Tìm kiếm thông tin"
            android:background="@drawable/edittext_background"
            android:paddingHorizontal="12dp"/>

        <Spinner
            android:id="@+id/spinnerFilter"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/spinner_background"/>
    </LinearLayout>

    <!-- Danh sách cảnh báo -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlerts"
        android:layout_below="@id/searchBar"
        android:layout_above="@id/footerMenu"
        android:layout_marginTop="4dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Thông báo khi rỗng -->
    <TextView
        android:id="@+id/txtEmpty"
        android:text="Chưa có dữ liệu SOS nào"
        android:textColor="#999999"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textSize="16sp"/>

    <!-- FOOTER MENU -->
    <include
        android:id="@+id/footerMenu"
        layout="@layout/admin_footer_menu"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="90dp" />
</RelativeLayout>
